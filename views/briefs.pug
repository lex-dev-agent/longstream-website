doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1")
    title Longstream Distillery — Briefs
    style.
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body { font-family: system-ui, -apple-system, sans-serif; background: #0e0e0e; color: #e0e0e0; }
      .nav { display: flex; gap: 0; border-bottom: 1px solid #2a2a2a; background: #141414; overflow-x: auto; -webkit-overflow-scrolling: touch; position: sticky; top: 0; z-index: 10; }
      .nav a { padding: 12px 20px; font-size: 14px; color: #888; text-decoration: none; white-space: nowrap; border-bottom: 2px solid transparent; transition: color 0.15s, border-color 0.15s; }
      .nav a:hover { color: #ccc; }
      .nav a.active { color: #e0e0e0; border-bottom-color: #5e6ad2; }
      .content { max-width: 780px; margin: 0 auto; padding: 40px 24px 80px; line-height: 1.7; }
      .content h1 { font-size: 28px; font-weight: 700; margin-bottom: 8px; color: #fff; }
      .content h2 { font-size: 22px; font-weight: 600; margin-top: 36px; margin-bottom: 12px; color: #f0f0f0; }
      .content h3 { font-size: 17px; font-weight: 600; margin-top: 28px; margin-bottom: 8px; color: #ddd; }
      .content h4 { font-size: 15px; font-weight: 600; margin-top: 20px; margin-bottom: 6px; color: #ccc; }
      .content p { margin-bottom: 14px; color: #bbb; }
      .content ul, .content ol { margin-bottom: 14px; padding-left: 24px; color: #bbb; }
      .content li { margin-bottom: 6px; }
      .content strong { color: #e0e0e0; }
      .content blockquote { border-left: 3px solid #5e6ad2; padding: 8px 16px; margin: 16px 0; color: #999; background: #1a1a1a; border-radius: 4px; }
      .content table { width: 100%; border-collapse: collapse; margin: 16px 0; font-size: 14px; }
      .content th, .content td { padding: 8px 12px; border: 1px solid #2a2a2a; text-align: left; }
      .content th { background: #1a1a1a; color: #ddd; font-weight: 600; }
      .content td { color: #bbb; }
      .content hr { border: none; border-top: 1px solid #2a2a2a; margin: 32px 0; }
      .content a { color: #5e6ad2; text-decoration: none; }
      .content a:hover { text-decoration: underline; }
      .content code { background: #1a1a1a; padding: 2px 6px; border-radius: 3px; font-size: 13px; }
      @media (max-width: 640px) {
        .nav a { padding: 10px 14px; font-size: 13px; }
        .content { padding: 24px 16px 60px; }
        .content h1 { font-size: 22px; }
        .content h2 { font-size: 18px; }
      }
  body
    nav.nav
      each doc in docs
        a(href="/brief/" + doc.slug class=(activeSlug === doc.slug ? "active" : ""))= doc.title
    .content
      | !{activeContent}
