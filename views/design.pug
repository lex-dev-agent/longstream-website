block content
  style.
    .vodka .label-brand {
      margin-left: 10px;
    }
  section.design-hero
    .container
      h1 Brand &amp; Print Design
      p.lead Crafting the visual identity for Longstream Distillery — from business cards to bottle labels, every detail distilled with care.

  section.bc-page
    div.container
      h2.bc-page-title Business Card
      p.bc-page-subtitle Proposed card for Ross Remnant — Longstream Distillery.

      .bc-showcase
        .bc-card-wrapper
          h3.bc-label Front
          .bc-card.bc-front#bc-preview-front
            +cardFrontContent
        .bc-card-wrapper
          h3.bc-label Back
          .bc-card.bc-back#bc-preview-back
            +cardBackContent

      .bc-download
        .bc-download-actions
          button.button.button-primary#bc-download-pdf(type="button") Download Print-Ready PDF
          button.button.button-secondary.bc-btn-png#bc-download-png(type="button") Download PNG
        p.bc-download-note
          | PDF includes ⅛″ bleed &amp; crop marks at 300 DPI.
          br
          | PNG downloads the card as shown above.

    //- Hidden print-ready cards with bleed + sharp edges for PDF capture
    .bc-print-offscreen(aria-hidden="true")
      .bc-card.bc-card--print.bc-front#bc-print-front
        +cardFrontContent
      .bc-card.bc-card--print.bc-back#bc-print-back
        +cardBackContent

  script(src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js")
  script(src="https://cdn.jsdelivr.net/npm/jspdf@2.5.2/dist/jspdf.umd.min.js")
  script.
    (function () {
      var TRIM_W = 3.5;
      var TRIM_H = 2;
      var BLEED  = 0.125;
      var PAGE_W = TRIM_W + BLEED * 2;
      var PAGE_H = TRIM_H + BLEED * 2;
      var DPI    = 300;

      var MARK_LEN = 0.08;
      var MARK_GAP = 0.02;

      var pdfBtn = document.getElementById('bc-download-pdf');
      var pngBtn = document.getElementById('bc-download-png');

      function capture(el, targetPxW, targetPxH) {
        var rect = el.getBoundingClientRect();
        var scale = Math.max(targetPxW / rect.width, targetPxH / rect.height);
        return html2canvas(el, {
          scale: scale,
          useCORS: true,
          backgroundColor: null,
          width: rect.width,
          height: rect.height,
          windowWidth: document.documentElement.scrollWidth
        });
      }

      function drawCropMarks(pdf) {
        pdf.setDrawColor(0);
        pdf.setLineWidth(0.003);
        var left   = BLEED;
        var top    = BLEED;
        var right  = BLEED + TRIM_W;
        var bottom = BLEED + TRIM_H;
        var corners = [
          { x: left,  y: top,    dx: -1, dy: -1 },
          { x: right, y: top,    dx:  1, dy: -1 },
          { x: left,  y: bottom, dx: -1, dy:  1 },
          { x: right, y: bottom, dx:  1, dy:  1 }
        ];
        corners.forEach(function (c) {
          pdf.line(c.x + c.dx * MARK_GAP, c.y, c.x + c.dx * (MARK_GAP + MARK_LEN), c.y);
          pdf.line(c.x, c.y + c.dy * MARK_GAP, c.x, c.y + c.dy * (MARK_GAP + MARK_LEN));
        });
      }

      function setLoading(btn, loading) {
        if (loading) {
          btn.dataset.originalText = btn.textContent;
          btn.textContent = 'Generating…';
          btn.disabled = true;
        } else {
          btn.textContent = btn.dataset.originalText;
          btn.disabled = false;
        }
      }

      function downloadDataUrl(dataUrl, filename) {
        var a = document.createElement('a');
        a.href = dataUrl;
        a.download = filename;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
      }

      pdfBtn.addEventListener('click', function () {
        setLoading(pdfBtn, true);
        var pxW = PAGE_W * DPI;
        var pxH = PAGE_H * DPI;
        var front = document.getElementById('bc-print-front');
        var back  = document.getElementById('bc-print-back');

        Promise.all([capture(front, pxW, pxH), capture(back, pxW, pxH)])
          .then(function (canvases) {
            var jsPDF = window.jspdf.jsPDF;
            var pdf = new jsPDF({ orientation: 'landscape', unit: 'in', format: [PAGE_W, PAGE_H] });
            canvases.forEach(function (canvas, i) {
              if (i > 0) pdf.addPage([PAGE_W, PAGE_H], 'landscape');
              pdf.addImage(canvas.toDataURL('image/png'), 'PNG', 0, 0, PAGE_W, PAGE_H);
              drawCropMarks(pdf);
            });
            pdf.save('ross-remnant-business-card.pdf');
          })
          .catch(function (err) {
            console.error('PDF generation failed:', err);
            alert('Something went wrong generating the PDF. Please try again.');
          })
          .finally(function () { setLoading(pdfBtn, false); });
      });

      pngBtn.addEventListener('click', function () {
        setLoading(pngBtn, true);
        var pxW = TRIM_W * DPI;
        var pxH = TRIM_H * DPI;
        var front = document.getElementById('bc-preview-front');
        var back  = document.getElementById('bc-preview-back');

        Promise.all([capture(front, pxW, pxH), capture(back, pxW, pxH)])
          .then(function (canvases) {
            downloadDataUrl(canvases[0].toDataURL('image/png'), 'ross-remnant-card-front.png');
            setTimeout(function () {
              downloadDataUrl(canvases[1].toDataURL('image/png'), 'ross-remnant-card-back.png');
            }, 300);
          })
          .catch(function (err) {
            console.error('PNG generation failed:', err);
            alert('Something went wrong generating the PNG. Please try again.');
          })
          .finally(function () { setLoading(pngBtn, false); });
      });
    })();

