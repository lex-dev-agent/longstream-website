doctype html
html(lang="en")
  head
    meta(charset="utf-8")
    meta(http-equiv="X-UA-Compatible", content="IE=edge")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title Longstream Botanicals | Homegrown New Zealand Gin
    link(rel="stylesheet", href="/styles/main.css")
    link(rel="preconnect", href="https://fonts.googleapis.com")
    link(rel="preconnect", href="https://fonts.gstatic.com", crossorigin="crossorigin")
    link(href="https://fonts.googleapis.com/css2?family=EB+Garamond:wght@400;600&family=Manrope:wght@400;600;700&display=swap", rel="stylesheet")
  body
    header.site-header
      div.container
        .brand
          img.logo(src="/images/logo.png", alt="Longstream Botanicals", width="40", height="40")
          .brand-text Longstream Botanicals
        nav.site-nav
          a.site-nav-link(href="#story") Our Story
          a.site-nav-link(href="#range") Range
          a.site-nav-link(href="#contact") Contact
          a.button.button-primary Order Online
    main(role="main")
      block content
    a.fab-order.button.button-primary(aria-label="Order here")
      span.fab-label ORDER HERE
    footer.site-footer
      div.container
        .newsletter-signup
          h3 Stay updated on new batches
          p Be the first to know when we release limited edition gin batches.
          form.newsletter-form(action="#" method="post")
            .form-group
              input(type="email" name="email" placeholder="Enter your email address" required)
            button.button.button-primary(type="submit") Subscribe
        .footer-info
          p Crafted in Mangaroa, Upper Hutt with pride.
          p © #{new Date().getFullYear()} Longstream Botanicals. All rights reserved.
    script.
      (function() {
        function getHeaderOffset() {
          var header = document.querySelector('.site-header');
          return header ? header.offsetHeight : 0;
        }

        function scrollToTarget(target) {
          if (!target) return;
          var top = target.getBoundingClientRect().top + window.pageYOffset - getHeaderOffset();
          window.scrollTo({ top: top, behavior: 'smooth' });
        }

        function cleanUrlHash() {
          if ('replaceState' in history) {
            history.replaceState(null, '', window.location.pathname + window.location.search);
          }
        }

        document.addEventListener('click', function(event) {
          var link = event.target.closest('a[href^="#"]');
          if (!link) return;
          var href = link.getAttribute('href');
          if (!href || href === '#') return;
          var id = href.slice(1);
          var target = document.getElementById(id);
          if (!target) return;
          event.preventDefault();
          scrollToTarget(target);
          cleanUrlHash();
        }, { passive: false });

        if (window.location.hash) {
          var initialId = window.location.hash.substring(1);
          var initialTarget = document.getElementById(initialId);
          if (initialTarget) {
            // Clean the hash first to avoid jump, then smooth scroll
            cleanUrlHash();
            window.requestAnimationFrame(function() {
              scrollToTarget(initialTarget);
            });
          }
        }
      })();
